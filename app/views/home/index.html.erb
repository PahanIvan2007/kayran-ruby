<div class="hero-section text-center">
  <div class="container position-relative">
    <h1 class="hero-title mb-3">Kairan</h1>
    <p class="hero-subtitle mb-4 mx-auto" style="max-width: 600px;">
      Платформа водных, спортивных и инклюзивных активностей
    </p>
    <div class="hero-cta d-flex gap-3 justify-content-center flex-wrap">
      <%= link_to new_user_session_path, class: "btn btn-light btn-lg px-5" do %>
        <i class="bi bi-box-arrow-in-right me-2"></i>Войти
      <% end %>
      <%= link_to new_user_registration_path, class: "btn btn-outline-light btn-lg px-5" do %>
        <i class="bi bi-person-plus me-2"></i>Регистрация
      <% end %>
    </div>
  </div>
</div>

<div class="container" style="margin-top: -2rem;">
  <div class="row g-4">
    <% features = [
      { icon: "bi-calendar-event", color: "blue", title: "События", desc: "Создание и управление событиями: аренда, тренировки, маршруты, соревнования" },
      { icon: "bi-map", color: "green", title: "Маршруты и GPS", desc: "GPS-трекинг, контрольные точки, офлайн-карты, уровни сложности" },
      { icon: "bi-boat", color: "cyan", title: "Прокат", desc: "Цифровой журнал аренды, QR-доступ, управление оборудованием" },
      { icon: "bi-trophy", color: "amber", title: "Соревнования", desc: "Турнирные сетки, судейство, результаты, команды" },
      { icon: "bi-heart-pulse", color: "rose", title: "Инклюзия", desc: "Адаптивные программы, профили безопасности, сопровождение" },
      { icon: "bi-building", color: "purple", title: "Франшизы", desc: "Управление точками, локальные администраторы, отчётность" },
    ] %>

    <% features.each_with_index do |f, i| %>
      <div class="col-12 col-sm-6 col-lg-4 animate-in">
        <div class="card card-feature h-100">
          <div class="card-body text-center">
            <div class="icon-wrapper <%= f[:color] %>">
              <i class="bi <%= f[:icon] %>"></i>
            </div>
            <h5 class="card-title"><%= f[:title] %></h5>
            <p class="card-text"><%= f[:desc] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @events_upcoming.any? %>
    <div class="mt-5">
      <h3 class="section-title">Предстоящие события</h3>
      <div class="list-group list-group-modern">
        <% @events_upcoming.each do |event| %>
          <%= link_to event_path(event), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
            <div>
              <strong><%= event.title %></strong>
              <small class="text-muted d-block"><%= event.point&.title %></small>
            </div>
            <span class="badge bg-primary badge-modern"><%= l(event.start_time, format: :short) %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
