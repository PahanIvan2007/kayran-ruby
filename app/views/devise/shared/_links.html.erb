<div class="d-flex flex-column gap-2">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Войти", new_session_path(resource_name), class: "btn btn-outline-primary btn-modern w-100" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Регистрация", new_registration_path(resource_name), class: "btn btn-outline-success btn-modern w-100" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Забыли пароль?", new_password_path(resource_name), class: "btn btn-link text-decoration-none p-0" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Не получили подтверждение?", new_confirmation_path(resource_name), class: "btn btn-link text-decoration-none p-0" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Не получили инструкции по разблокировке?", new_unlock_path(resource_name), class: "btn btn-link text-decoration-none p-0" %>
  <% end %>
</div>
