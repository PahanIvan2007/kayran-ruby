<div class="page-header">
  <div class="container d-flex justify-content-between align-items-center">
    <div>
      <h1>Франшизы</h1>
      <p>Управление сетью точек и партнёров</p>
    </div>
    <%= link_to new_franchise_path, class: "btn btn-light btn-modern" do %>
      <i class="bi bi-plus-lg me-1"></i> Новая франшиза
    <% end %>
  </div>
</div>

<div class="container">
  <div class="table-responsive">
    <table class="table table-modern align-middle">
      <thead>
        <tr>
          <th>Название</th>
          <th>Владелец</th>
          <th>Статус</th>
          <th>Точек</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @franchises.each do |f| %>
          <tr>
            <td><%= link_to f.title, f, class: "fw-medium text-decoration-none" %></td>
            <td><%= f.owner&.full_name || "—" %></td>
            <td><span class="badge badge-modern bg-<%= f.active? ? 'success' : 'secondary' %>"><%= t("activerecord.attributes.franchise.statuses.#{f.status}") %></span></td>
            <td><span class="badge badge-modern bg-primary"><%= f.points.count %></span></td>
            <td><%= link_to edit_franchise_path(f), class: "btn btn-sm btn-outline-primary" do %><i class="bi bi-pencil"></i><% end %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
