<div class="page-header">
  <div class="container d-flex justify-content-between align-items-center">
    <div>
      <h1>Маршруты</h1>
      <p>Водные маршруты и треки</p>
    </div>
    <%= link_to new_route_path, class: "btn btn-light btn-modern" do %>
      <i class="bi bi-plus-lg me-1"></i> Новый маршрут
    <% end %>
  </div>
</div>

<div class="container">
  <div class="row g-4">
    <% @routes.each do |route| %>
      <div class="col-12 col-md-6 col-lg-4 animate-in">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= link_to route.title, route, class: "text-decoration-none stretched-link" %></h5>
            <div class="mb-2">
              <span class="badge badge-modern bg-<%= route.easy? ? 'success' : route.medium? ? 'warning' : 'danger' %>"><%= t("activerecord.attributes.route.difficulties.#{route.difficulty}") %></span>
              <span class="badge badge-modern bg-info"><%= t("activerecord.attributes.route.route_types.#{route.route_type}") %></span>
            </div>
            <% if route.distance_km %>
              <p class="card-text small mb-1"><i class="bi bi-rulers text-primary me-1"></i> <%= route.distance_km %> км</p>
            <% end %>
            <p class="card-text small text-muted mb-0"><i class="bi bi-geo-alt me-1"></i> Точек: <%= route.route_points.count %></p>
          </div>
          <div class="card-footer bg-transparent border-top d-flex gap-1">
            <%= link_to route, class: "btn btn-sm btn-outline-primary" do %><i class="bi bi-eye"></i> Подробнее<% end %>
            <%= link_to edit_route_path(route), class: "btn btn-sm btn-outline-secondary" do %><i class="bi bi-pencil"></i><% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
