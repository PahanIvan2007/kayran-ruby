<div class="page-header">
  <div class="container d-flex justify-content-between align-items-center">
    <div>
      <h1>Точки</h1>
      <p>Базы, причалы и места активностей</p>
    </div>
    <%= link_to new_point_path, class: "btn btn-light btn-modern" do %>
      <i class="bi bi-plus-lg me-1"></i> Новая точка
    <% end %>
  </div>
</div>

<div class="container">
  <div class="row g-4">
    <% @points.each do |point| %>
      <div class="col-12 col-md-6 col-lg-4 animate-in">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title mb-0"><%= link_to point.title, point, class: "text-decoration-none stretched-link" %></h5>
            </div>
            <div class="mb-2">
              <span class="badge badge-modern bg-info"><%= t("activerecord.attributes.point.point_types.#{point.point_type}") %></span>
              <span class="badge badge-modern bg-<%= point.active? ? 'success' : 'secondary' %>"><%= t("activerecord.attributes.point.statuses.#{point.status}") %></span>
            </div>
            <% if point.address.present? %>
              <p class="card-text small mb-1"><i class="bi bi-geo-alt text-primary me-1"></i> <%= point.address %></p>
            <% end %>
            <p class="card-text small text-muted mb-0"><i class="bi bi-boat me-1"></i> Лодок: <%= point.boats.count %></p>
          </div>
          <div class="card-footer bg-transparent border-top d-flex gap-1">
            <%= link_to qr_point_path(point), class: "btn btn-sm btn-outline-secondary", target: "_blank", title: "QR-код" do %><i class="bi bi-qr-code"></i> QR<% end %>
            <%= link_to "Изменить", edit_point_path(point), class: "btn btn-sm btn-outline-primary" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
