<%= form_with(model: boat, class: "row g-4") do |f| %>
  <% if boat.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <div>
          <strong><%= pluralize(boat.errors.count, "ошибка") %>:</strong>
          <ul class="mb-0 mt-1"><% boat.errors.each do |err| %><li><%= err.full_message %></li><% end %></ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="col-12 col-md-6">
    <%= f.label :serial_number, class: "form-label fw-medium" %>
    <%= f.text_field :serial_number, class: "form-control", required: true, placeholder: "KA-001" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :boat_type, class: "form-label fw-medium" %>
    <%= f.text_field :boat_type, class: "form-control", placeholder: "Надувная, каяк, байдарка..." %>
  </div>
  <div class="col-12 col-md-4">
    <%= f.label :color, class: "form-label fw-medium" %>
    <%= f.text_field :color, class: "form-control" %>
  </div>
  <div class="col-12 col-md-4">
    <%= f.label :capacity, class: "form-label fw-medium" %>
    <%= f.number_field :capacity, class: "form-control", placeholder: "2" %>
  </div>
  <div class="col-12 col-md-4">
    <%= f.label :status, class: "form-label fw-medium" %>
    <%= f.select :status, Boat.statuses.keys.map { |k| [t("activerecord.attributes.boat.statuses.#{k}"), k] }, {}, class: "form-select" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :condition_level, class: "form-label fw-medium" %>
    <%= f.select :condition_level, Boat.condition_levels.keys.map { |k| [t("activerecord.attributes.boat.condition_levels.#{k}"), k] }, {}, class: "form-select" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :last_service_date, class: "form-label fw-medium" %>
    <%= f.date_field :last_service_date, class: "form-control" %>
  </div>
  <div class="col-12">
    <%= f.label :point_id, class: "form-label fw-medium" %>
    <%= f.collection_select :point_id, Point.active.order(:title), :id, :title, { include_blank: "—" }, class: "form-select" %>
  </div>
  <div class="col-12 d-flex gap-2 pt-3 border-top">
    <%= f.submit class: "btn btn-primary btn-modern px-4" %>
    <%= link_to "Отмена", boats_path, class: "btn btn-outline-secondary btn-modern px-4" %>
  </div>
<% end %>
