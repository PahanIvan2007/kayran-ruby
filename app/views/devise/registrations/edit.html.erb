<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white mb-3" style="width: 64px; height: 64px;">
          <i class="bi bi-person-gear" style="font-size: 1.75rem;"></i>
        </div>
        <h2 class="fw-bold">Редактировать профиль</h2>
      </div>

      <div class="card border-0 shadow-lg" style="border-radius: 16px;">
        <div class="card-body p-4">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <%= f.label :first_name, class: "form-label fw-medium" %>
                <%= f.text_field :first_name, class: "form-control" %>
              </div>
              <div class="col-12 col-md-6">
                <%= f.label :last_name, class: "form-label fw-medium" %>
                <%= f.text_field :last_name, class: "form-control" %>
              </div>
              <div class="col-12 col-md-6">
                <%= f.label :phone, class: "form-label fw-medium" %>
                <%= f.phone_field :phone, class: "form-control" %>
              </div>
              <div class="col-12 col-md-6">
                <%= f.label :email, class: "form-label fw-medium" %>
                <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
              </div>

              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <div class="col-12">
                  <div class="alert alert-info">Ожидает подтверждения: <%= resource.unconfirmed_email %></div>
                </div>
              <% end %>

              <div class="col-12">
                <hr class="my-3">
                <h6 class="fw-bold"><i class="bi bi-key me-2 text-warning"></i>Изменить пароль</h6>
              </div>

              <div class="col-12 col-md-6">
                <%= f.label :password, class: "form-label fw-medium" %>
                <small class="text-muted">(оставьте пустым, если не хотите менять)</small>
                <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
                <% if @minimum_password_length %>
                  <small class="text-muted"><%= @minimum_password_length %> символов минимум</small>
                <% end %>
              </div>
              <div class="col-12 col-md-6">
                <%= f.label :password_confirmation, class: "form-label fw-medium" %>
                <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
              </div>
              <div class="col-12">
                <%= f.label :current_password, class: "form-label fw-medium" %>
                <small class="text-danger">(нужен для подтверждения изменений)</small>
                <%= f.password_field :current_password, class: "form-control", autocomplete: "current-password" %>
              </div>

              <div class="col-12">
                <hr class="my-3">
                <h6 class="fw-bold"><i class="bi bi-heart-pulse me-2 text-danger"></i>Медицинские данные</h6>
              </div>

              <div class="col-12">
                <%= f.label :medical_flags, class: "form-label fw-medium" %>
                <%= f.text_area :medical_flags, class: "form-control", rows: 2, placeholder: "Аллергии, ограничения..." %>
              </div>
              <div class="col-12 col-md-6">
                <%= f.label :accessibility_level, class: "form-label fw-medium" %>
                <%= f.select :accessibility_level, User.accessibility_levels.keys.map { |k| [t("activerecord.attributes.user.accessibility_levels.#{k}"), k] }, {}, class: "form-select" %>
              </div>
            </div>

            <div class="d-grid mt-4">
              <%= f.submit "Сохранить", class: "btn btn-primary btn-lg btn-modern" %>
            </div>
          <% end %>

          <hr class="mt-4">
          <div class="d-flex justify-content-between">
            <%= link_to :back, class: "btn btn-outline-secondary btn-modern" do %><i class="bi bi-arrow-left me-1"></i> Назад<% end %>
            <%= button_to "Удалить аккаунт", registration_path(resource_name), data: { confirm: "Вы уверены?", turbo_confirm: "Вы уверены?" }, method: :delete, class: "btn btn-outline-danger btn-modern" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
