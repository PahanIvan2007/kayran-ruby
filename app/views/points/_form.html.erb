<%= form_with(model: point, class: "row g-4") do |f| %>
  <% if point.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <div>
          <strong><%= pluralize(point.errors.count, "ошибка") %>:</strong>
          <ul class="mb-0 mt-1"><% point.errors.each do |err| %><li><%= err.full_message %></li><% end %></ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="col-12">
    <%= f.label :title, class: "form-label fw-medium" %>
    <%= f.text_field :title, class: "form-control", required: true, placeholder: "Название точки" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :point_type, "Тип точки", class: "form-label fw-medium" %>
    <%= f.select :point_type, Point.point_types.keys.map { |k| [t("activerecord.attributes.point.point_types.#{k}"), k] }, {}, class: "form-select" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :status, class: "form-label fw-medium" %>
    <%= f.select :status, Point.statuses.keys.map { |k| [t("activerecord.attributes.point.statuses.#{k}"), k] }, {}, class: "form-select" %>
  </div>
  <div class="col-12">
    <%= f.label :address, class: "form-label fw-medium" %>
    <%= f.text_field :address, class: "form-control", placeholder: "Адрес или описание местоположения" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :lat, class: "form-label fw-medium" %>
    <%= f.text_field :lat, class: "form-control", placeholder: "55.7558" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :lng, class: "form-label fw-medium" %>
    <%= f.text_field :lng, class: "form-control", placeholder: "37.6173" %>
  </div>
  <div class="col-12 col-md-6">
    <%= f.label :franchise_id, class: "form-label fw-medium" %>
    <%= f.collection_select :franchise_id, Franchise.active.order(:title), :id, :title, { include_blank: "—" }, class: "form-select" %>
  </div>
  <div class="col-12 d-flex gap-2 pt-3 border-top">
    <%= f.submit class: "btn btn-primary btn-modern px-4" %>
    <%= link_to "Отмена", points_path, class: "btn btn-outline-secondary btn-modern px-4" %>
  </div>
<% end %>
