<div class="container py-4">
  <div class="mb-3">
    <%= link_to franchises_path, class: "btn btn-outline-secondary btn-sm btn-modern" do %><i class="bi bi-arrow-left me-1"></i> Назад<% end %>
  </div>

  <div class="card border-0 shadow-lg" style="border-radius: 16px;">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <div class="d-flex gap-2 mb-1">
            <span class="badge badge-modern bg-<%= @franchise.active? ? 'success' : 'secondary' %>"><%= t("activerecord.attributes.franchise.statuses.#{@franchise.status}") %></span>
          </div>
          <h1 class="fw-bold mb-1" style="font-size: 1.75rem;"><i class="bi bi-building text-primary me-2"></i><%= @franchise.title %></h1>
        </div>
        <%= link_to edit_franchise_path(@franchise), class: "btn btn-primary btn-modern" do %><i class="bi bi-pencil"></i> Изменить<% end %>
      </div>

      <div class="row g-4">
        <div class="col-12 col-sm-6">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10 text-warning" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-person fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Владелец</small>
              <span class="fw-medium"><%= @franchise.owner&.full_name || "—" %></span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-info bg-opacity-10 text-info" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-geo-alt fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Точки</small>
              <span class="fw-medium"><%= @points.count %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3" style="border-radius: 12px;">
    <div class="card-header bg-transparent border-bottom fw-bold py-3"><i class="bi bi-pin-map me-2 text-primary"></i>Точки франшизы</div>
    <div class="list-group list-group-flush">
      <% if @points.any? %>
        <% @points.each do |p| %>
          <%= link_to point_path(p), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3" do %>
            <span class="fw-medium"><%= p.title %></span>
            <span class="badge badge-modern bg-<%= p.active? ? 'success' : 'secondary' %>"><%= t("activerecord.attributes.point.statuses.#{p.status}") %></span>
          <% end %>
        <% end %>
      <% else %>
        <div class="list-group-item text-muted text-center py-4">Нет точек</div>
      <% end %>
    </div>
  </div>
</div>
