<div class="container py-4">
  <div class="mb-3">
    <%= link_to routes_path, class: "btn btn-outline-secondary btn-sm btn-modern" do %><i class="bi bi-arrow-left me-1"></i> Назад<% end %>
  </div>

  <div class="card border-0 shadow-lg" style="border-radius: 16px;">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <div class="d-flex gap-2 mb-1">
            <span class="badge badge-modern bg-<%= @route.easy? ? 'success' : @route.medium? ? 'warning' : 'danger' %>"><%= t("activerecord.attributes.route.difficulties.#{@route.difficulty}") %></span>
            <span class="badge badge-modern bg-info"><%= t("activerecord.attributes.route.route_types.#{@route.route_type}") %></span>
            <span class="badge badge-modern bg-<%= @route.active? ? 'success' : 'secondary' %>"><%= t("activerecord.attributes.route.statuses.#{@route.status}") %></span>
          </div>
          <h1 class="fw-bold mb-1" style="font-size: 1.75rem;"><i class="bi bi-signpost-2 text-primary me-2"></i><%= @route.title %></h1>
        </div>
        <%= link_to edit_route_path(@route), class: "btn btn-primary btn-modern" do %><i class="bi bi-pencil"></i> Изменить<% end %>
      </div>

      <div class="row g-4">
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10 text-warning" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-rulers fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Расстояние</small>
              <span class="fw-medium"><%= @route.distance_km %> км</span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-info bg-opacity-10 text-info" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-clock fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Длительность</small>
              <span class="fw-medium"><%= @route.estimated_duration %> мин.</span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 text-success" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-geo-alt fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Точек маршрута</small>
              <span class="fw-medium"><%= @route_points.count %></span>
            </div>
          </div>
        </div>
      </div>

      <% if @route.description.present? %>
        <div class="mt-3 p-3 rounded-3" style="background: #f8fafc;">
          <h6 class="fw-bold"><i class="bi bi-file-text me-2 text-primary"></i>Описание</h6>
          <p class="text-muted mb-0"><%= @route.description %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3" style="border-radius: 12px;">
    <div class="card-header bg-transparent border-bottom fw-bold py-3"><i class="bi bi-pin-map me-2 text-primary"></i>Контрольные точки маршрута</div>
    <div class="list-group list-group-flush">
      <% if @route_points.any? %>
        <% @route_points.each.with_index(1) do |point, i| %>
          <div class="list-group-item py-3">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <span class="fw-medium"><strong>#<%= i %></strong> <%= point.title || "Точка #{i}" %></span>
                <br><small class="text-muted"><%= point.lat %>, <%= point.lng %></small>
              </div>
              <span class="badge badge-modern bg-info"><%= t("activerecord.attributes.route_point.checkpoint_types.#{point.checkpoint_type}") %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="list-group-item text-muted text-center py-4">Нет контрольных точек</div>
      <% end %>
    </div>
  </div>
</div>
