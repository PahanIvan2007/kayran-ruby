<div class="container py-4">
  <div class="mb-3">
    <%= link_to teams_path, class: "btn btn-outline-secondary btn-sm btn-modern" do %><i class="bi bi-arrow-left me-1"></i> Назад<% end %>
  </div>

  <div class="card border-0 shadow-lg" style="border-radius: 16px;">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <div class="d-flex gap-2 mb-1">
            <span class="badge badge-modern bg-<%= @team.active? ? 'success' : 'secondary' %>"><%= t("activerecord.attributes.team.statuses.#{@team.status}") %></span>
          </div>
          <h1 class="fw-bold mb-1" style="font-size: 1.75rem;"><i class="bi bi-people-fill text-primary me-2"></i><%= @team.title %></h1>
        </div>
        <%= link_to edit_team_path(@team), class: "btn btn-primary btn-modern" do %><i class="bi bi-pencil"></i> Изменить<% end %>
      </div>

      <div class="row g-4">
        <div class="col-12 col-sm-6">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10 text-warning" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-person-badge fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Капитан</small>
              <span class="fw-medium"><%= @team.captain&.full_name || "—" %></span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 text-success" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-people fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Участники</small>
              <span class="fw-medium"><%= @team.team_members.count %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
