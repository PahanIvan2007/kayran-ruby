<div class="container py-4">
  <div class="mb-3">
    <%= link_to rentals_path, class: "btn btn-outline-secondary btn-sm btn-modern" do %><i class="bi bi-arrow-left me-1"></i> Назад<% end %>
  </div>

  <div class="card border-0 shadow-lg" style="border-radius: 16px;">
    <div class="card-body p-4">
      <div class="d-flex align-items-center gap-2 mb-1">
        <span class="badge badge-modern bg-<%= @rental.active? ? 'success' : @rental.completed? ? 'secondary' : 'danger' %>"><%= t("activerecord.attributes.rental.statuses.#{@rental.status}") %></span>
      </div>
      <h1 class="fw-bold mb-4" style="font-size: 1.75rem;"><i class="bi bi-receipt text-primary me-2"></i>Аренда #<%= @rental.id %></h1>

      <div class="row g-4">
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-info bg-opacity-10 text-info" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-boat fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Лодка</small>
              <span class="fw-medium"><%= link_to @rental.boat&.serial_number, @rental.boat %></span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10 text-primary" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-calendar-event fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Событие</small>
              <span class="fw-medium"><%= link_to @rental.event&.title, @rental.event %></span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 text-success" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-person fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Пользователь</small>
              <span class="fw-medium"><%= @rental.user&.full_name %></span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10 text-warning" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-play-circle fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Начало</small>
              <span class="fw-medium"><%= l(@rental.start_time, format: :long) %></span>
            </div>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background: #f8fafc;">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 text-danger" style="width: 48px; height: 48px; min-width: 48px;"><i class="bi bi-stop-circle fs-5"></i></div>
            <div>
              <small class="text-muted d-block">Окончание</small>
              <span class="fw-medium"><%= l(@rental.end_time, format: :long) if @rental.end_time %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <%= link_to rentals_path, class: "btn btn-outline-secondary btn-modern" do %><i class="bi bi-arrow-left me-1"></i> Назад к списку<% end %>
  </div>
</div>
