<%= form_with(model: team, class: "row g-4") do |f| %>
  <% if team.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <div>
          <strong><%= pluralize(team.errors.count, "ошибка") %>:</strong>
          <ul class="mb-0 mt-1"><% team.errors.each do |err| %><li><%= err.full_message %></li><% end %></ul>
        </div>
      </div>
    </div>
  <% end %>
  <div class="col-12"><%= f.label :title, class: "form-label fw-medium" %><%= f.text_field :title, class: "form-control", required: true, placeholder: "Название команды" %></div>
  <div class="col-12 col-md-6"><%= f.label :captain_id, class: "form-label fw-medium" %><%= f.collection_select :captain_id, User.active.order(:first_name), :id, :full_name, { include_blank: "—" }, class: "form-select" %></div>
  <div class="col-12 col-md-6"><%= f.label :status, class: "form-label fw-medium" %><%= f.select :status, Team.statuses.keys.map { |k| [t("activerecord.attributes.team.statuses.#{k}"), k] }, {}, class: "form-select" %></div>
  <div class="col-12 d-flex gap-2 pt-3 border-top"><%= f.submit class: "btn btn-primary btn-modern px-4" %><%= link_to "Отмена", teams_path, class: "btn btn-outline-secondary btn-modern px-4" %></div>
<% end %>
