<div class="page-header">
  <div class="container">
    <h1>Новая аренда</h1>
    <p>Оформление аренды плавсредства</p>
  </div>
</div>
<div class="container">
  <div class="card border-0 shadow-sm" style="border-radius: 12px; max-width: 700px;">
    <div class="card-body p-4">
      <%= form_with(model: @rental, class: "row g-4") do |f| %>
        <% if @rental.errors.any? %>
          <div class="col-12">
            <div class="alert alert-danger d-flex align-items-center gap-2">
              <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
              <div>
                <strong><%= pluralize(@rental.errors.count, "ошибка") %>:</strong>
                <ul class="mb-0 mt-1"><% @rental.errors.each do |err| %><li><%= err.full_message %></li><% end %></ul>
              </div>
            </div>
          </div>
        <% end %>

        <div class="col-12">
          <%= f.label :event_id, class: "form-label fw-medium" %>
          <%= f.collection_select :event_id, Event.upcoming, :id, :title, { include_blank: "—" }, class: "form-select" %>
        </div>
        <div class="col-12">
          <%= f.label :boat_id, class: "form-label fw-medium" %>
          <%= f.collection_select :boat_id, @boats, :id, :serial_number, { include_blank: "—" }, class: "form-select" %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :start_time, class: "form-label fw-medium" %>
          <%= f.datetime_field :start_time, class: "form-control", value: Time.current.strftime("%Y-%m-%dT%H:%M") %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :end_time, class: "form-label fw-medium" %>
          <%= f.datetime_field :end_time, class: "form-control" %>
        </div>
        <div class="col-12 d-flex gap-2 pt-3 border-top">
          <%= f.submit "Начать аренду", class: "btn btn-primary btn-modern px-4" %>
          <%= link_to "Отмена", rentals_path, class: "btn btn-outline-secondary btn-modern px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
