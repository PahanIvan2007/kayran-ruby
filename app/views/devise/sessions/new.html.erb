<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white mb-3" style="width: 64px; height: 64px;">
          <i class="bi bi-water" style="font-size: 1.75rem;"></i>
        </div>
        <h2 class="fw-bold">Добро пожаловать</h2>
        <p class="text-muted">Войдите в свой аккаунт</p>
      </div>

      <div class="card border-0 shadow-lg" style="border-radius: 16px;">
        <div class="card-body p-4">
          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label fw-medium" %>
              <%= f.email_field :email, class: "form-control", autofocus: true, autocomplete: "email", placeholder: "email@example.com" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label fw-medium" %>
              <%= f.password_field :password, class: "form-control", autocomplete: "current-password", placeholder: "••••••••" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="mb-3 form-check">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, class: "form-check-label" %>
              </div>
            <% end %>

            <div class="d-grid">
              <%= f.submit "Войти", class: "btn btn-primary btn-lg btn-modern" %>
            </div>
          <% end %>

          <div class="mt-4 text-center">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>

      <p class="text-center text-muted small mt-3">
        <i class="bi bi-shield-check me-1"></i> Kairan — платформа активностей
      </p>
    </div>
  </div>
</div>
